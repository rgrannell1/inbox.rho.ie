{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "cmstr": ["./vendor/cmstr/mod.ts"]
    }
  },
  "include": ["ts/**/*.ts"]
}
